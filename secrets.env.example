# Copy to secrets.env and fill in. secrets.env is gitignored — never commit it.
# These values are read at runtime and merged with config/config.yaml.

# PAN-OS / Panorama API key (generate via: /api/?type=keygen&user=<u>&password=<p>
# against the target firewall or Panorama — see README "Getting an API key").
# One default key here; override per-device in config.yaml if a device needs a
# different one.
PANOS_API_KEY=changeme
